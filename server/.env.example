# ====================================
# TimeTask Server Environment Variables
# ====================================

# Environment
NODE_ENV="development"  # development | staging | production
PORT=3000
LOG_LEVEL="info"  # error | warn | info | debug

# ====================================
# Database Configuration
# ====================================
DATABASE_URL="postgresql://username:password@localhost:5432/timetask?schema=public"
DATABASE_CONNECTION_LIMIT=10  # Connection pool size
DATABASE_TIMEOUT=20000  # Query timeout in ms

# ====================================
# Redis Configuration (Optional)
# ====================================
REDIS_URL="redis://:password@localhost:6379"
REDIS_TTL=3600  # Cache TTL in seconds

# ====================================
# JWT Authentication
# ====================================
# Generate with: openssl rand -base64 32
JWT_SECRET="your-super-secret-jwt-key-min-32-chars-CHANGE-THIS"
JWT_EXPIRES_IN="7d"
REFRESH_TOKEN_SECRET="your-refresh-token-secret-min-32-chars-CHANGE-THIS"
REFRESH_TOKEN_EXPIRES_IN="30d"

# ====================================
# Security Configuration
# ====================================
BCRYPT_ROUNDS=12
CORS_ORIGIN="http://localhost:5173"  # Comma-separated for multiple origins
CORS_CREDENTIALS=true
HELMET_CSP=true

# ====================================
# Rate Limiting
# ====================================
RATE_LIMIT_WINDOW=15  # Window in minutes
RATE_LIMIT_MAX_REQUESTS=100  # Max requests per window
LOGIN_RATE_LIMIT_ATTEMPTS=5  # Max login attempts
LOGIN_RATE_LIMIT_WINDOW=15  # Login window in minutes

# ====================================
# Email Configuration (SMTP)
# ====================================
SMTP_ENABLED=false  # Set to true in production
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_SECURE=false  # true for 465, false for other ports
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-specific-password"
FROM_EMAIL="noreply@timetask.com"
FROM_NAME="TimeTask System"

# For development, use Mailhog
MAILHOG_HOST="localhost"
MAILHOG_PORT=1025

# ====================================
# File Upload Configuration
# ====================================
UPLOAD_DIR="./uploads"
MAX_FILE_SIZE=52428800  # 50MB in bytes
ALLOWED_FILE_TYPES="jpg,jpeg,png,gif,pdf,doc,docx,xls,xlsx,txt,zip,rar"
IMAGE_OPTIMIZATION=true
IMAGE_MAX_WIDTH=2048
IMAGE_MAX_HEIGHT=2048
IMAGE_QUALITY=85

# ====================================
# Timer & Alert Settings
# ====================================
TIMER_ALERT_INTERFACE_MINUTES=30  # Alert in UI after X minutes
TIMER_ALERT_EMAIL_HOURS=2  # Email alert after X hours
TIMER_MAX_CONCURRENT=3  # Max concurrent timers per user
TIMER_AUTO_STOP_HOURS=12  # Auto-stop forgotten timers after X hours

# ====================================
# Session Configuration
# ====================================
SESSION_SECRET="your-session-secret-CHANGE-THIS"
SESSION_MAX_AGE=86400000  # 24 hours in milliseconds
SESSION_SECURE_COOKIE=false  # Set to true in production with HTTPS

# ====================================
# Socket.IO Configuration
# ====================================
SOCKET_PING_TIMEOUT=60000
SOCKET_PING_INTERVAL=25000
SOCKET_MAX_HTTP_BUFFER_SIZE=1000000  # 1MB

# ====================================
# Monitoring & Analytics
# ====================================
SENTRY_DSN=""  # Sentry error tracking
GOOGLE_ANALYTICS_ID=""  # Google Analytics
MIXPANEL_TOKEN=""  # Mixpanel analytics

# ====================================
# External Services (Optional)
# ====================================
# AWS S3 for file storage
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_REGION="us-east-1"
S3_BUCKET_NAME=""

# Google OAuth (optional)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_CALLBACK_URL="http://localhost:3000/api/auth/google/callback"

# Slack Integration (optional)
SLACK_WEBHOOK_URL=""
SLACK_CLIENT_ID=""
SLACK_CLIENT_SECRET=""

# ====================================
# Backup Configuration
# ====================================
BACKUP_ENABLED=false
BACKUP_SCHEDULE="0 2 * * *"  # Cron format (daily at 2 AM)
BACKUP_RETENTION_DAYS=30
BACKUP_S3_BUCKET=""
BACKUP_LOCAL_PATH="./backups"

# ====================================
# Development Tools
# ====================================
SWAGGER_ENABLED=false  # Enable Swagger API docs
GRAPHQL_PLAYGROUND=false  # Enable GraphQL playground
DEBUG_SQL=false  # Log SQL queries

# ====================================
# Performance Tuning
# ====================================
CLUSTER_WORKERS=0  # 0 = auto (number of CPU cores)
MEMORY_LIMIT="1G"  # Process memory limit
REQUEST_TIMEOUT=30000  # Request timeout in ms
BODY_SIZE_LIMIT="10mb"  # Max request body size

# ====================================
# Localization
# ====================================
DEFAULT_LANGUAGE="he"  # Hebrew
SUPPORTED_LANGUAGES="he,en,ar,ru"
TIMEZONE="Asia/Jerusalem"

# ====================================
# Feature Flags
# ====================================
FEATURE_REGISTRATION_OPEN=false
FEATURE_SOCIAL_LOGIN=false
FEATURE_TWO_FACTOR_AUTH=false
FEATURE_API_RATE_LIMIT=true
FEATURE_WEBSOCKET=true
FEATURE_EMAIL_VERIFICATION=false
FEATURE_PASSWORD_RESET=true
FEATURE_FILE_UPLOAD=true
FEATURE_EXPORT_REPORTS=true
FEATURE_BULK_OPERATIONS=true
FEATURE_AUDIT_LOG=true

# ====================================
# Admin Configuration
# ====================================
ADMIN_EMAIL="admin@timetask.com"
ADMIN_INITIAL_PASSWORD="ChangeThisImmediately!"
SUPER_ADMIN_IPS=""  # Comma-separated IP whitelist

# ====================================
# Maintenance Mode
# ====================================
MAINTENANCE_MODE=false
MAINTENANCE_MESSAGE="המערכת בתחזוקה. נשוב בקרוב."
MAINTENANCE_ALLOWED_IPS=""  # IPs that can access during maintenance