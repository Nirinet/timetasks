// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  EMPLOYEE
  CLIENT
}

enum ProjectStatus {
  ACTIVE
  ON_HOLD
  COMPLETED
}

enum TaskStatus {
  NEW
  IN_PROGRESS
  WAITING_CLIENT
  COMPLETED
}

enum Priority {
  URGENT_IMPORTANT // Level 1 - Red
  IMPORTANT        // Level 2 - Orange
  NORMAL          // Level 3 - Yellow
  LOW             // Level 4 - Green
}

enum TimerStatus {
  ACTIVE
  PAUSED
  COMPLETED
}

enum AlertType {
  NEW_TASK
  STATUS_CHANGE
  NEW_COMMENT
  TASK_ASSIGNMENT
  DEADLINE_APPROACHING
  DEADLINE_EXCEEDED
  ACTIVE_TIMER
  NEW_FILE
  PRIORITY_CHANGE
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  firstName String
  lastName  String
  phone     String?
  role      UserRole
  isActive  Boolean  @default(true)
  joinDate  DateTime @default(now())
  lastLogin DateTime?

  // Password reset
  resetToken        String?
  resetTokenExpiry  DateTime?

  // User preferences
  emailNotifications Boolean @default(true)
  timerAlerts       Boolean @default(true)
  language          String  @default("he")

  // Link CLIENT-role user to a Client business entity (optional)
  clientEntity    Client?  @relation("UserClientEntity", fields: [clientEntityId], references: [id], onDelete: SetNull)
  clientEntityId  String?

  // Relations
  createdClients    Client[]         @relation("ClientCreatedBy")
  assignedTasks     TaskAssignment[]
  projectAssignments ProjectAssignment[]
  timeRecords       TimeRecord[]
  comments          Comment[]
  uploadedFiles     FileAttachment[]
  sentAlerts        Alert[]          @relation("AlertSender")
  receivedAlerts    Alert[]          @relation("AlertReceiver")
  createdProjects   Project[]        @relation("ProjectCreatedBy")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clientEntityId])
  @@map("users")
}

model Client {
  id            String    @id @default(uuid())
  name          String
  contactPerson String
  phone         String?
  email         String?
  address       String?
  joinDate      DateTime  @default(now())
  isActive      Boolean   @default(true)
  notes         String?

  // Relations
  createdBy     User      @relation("ClientCreatedBy", fields: [createdById], references: [id])
  createdById   String
  projects      ProjectClient[]
  assignedTasks TaskAssignment[]
  linkedUsers   User[]    @relation("UserClientEntity")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("clients")
}

model Project {
  id          String        @id @default(uuid())
  name        String
  description String?
  startDate   DateTime      @default(now())
  targetDate  DateTime?
  status      ProjectStatus @default(ACTIVE)
  hoursBudget Float?
  isTemplate  Boolean       @default(false)

  // Relations
  clients     ProjectClient[]
  createdBy   User      @relation("ProjectCreatedBy", fields: [createdById], references: [id])
  createdById String
  tasks       Task[]
  comments    Comment[]
  assignedUsers ProjectAssignment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@map("projects")
}

model Task {
  id              String     @id @default(uuid())
  title           String
  description     String?
  priority        Priority   @default(NORMAL)
  status          TaskStatus @default(NEW)
  creationDate    DateTime   @default(now())
  deadline        DateTime?
  timeEstimate    Float?     // in hours

  // Hierarchy support
  parentTask      Task?      @relation("TaskHierarchy", fields: [parentTaskId], references: [id])
  parentTaskId    String?
  subtasks        Task[]     @relation("TaskHierarchy")

  // Relations
  project         Project             @relation(fields: [projectId], references: [id])
  projectId       String
  assignedUsers   TaskAssignment[]
  timeRecords     TimeRecord[]
  comments        Comment[]
  files           FileAttachment[]
  changes         TaskChangeHistory[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId])
  @@index([status])
  @@index([parentTaskId])
  @@index([creationDate])
  @@map("tasks")
}

model TaskAssignment {
  id     String @id @default(uuid())

  // Relations
  task   Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)
  taskId String

  // Can be assigned to either user or client
  user     User?   @relation(fields: [userId], references: [id])
  userId   String?
  client   Client? @relation(fields: [clientId], references: [id])
  clientId String?

  assignedAt DateTime @default(now())
  assignedBy String   // User ID who made the assignment

  @@unique([taskId, userId])
  @@unique([taskId, clientId])
  @@index([clientId])
  @@index([userId])
  @@map("task_assignments")
}

model TimeRecord {
  id          String      @id @default(uuid())
  date        DateTime    @default(now())
  startTime   DateTime
  endTime     DateTime?
  duration    Int?        // in minutes, calculated automatically
  description String?
  status      TimerStatus @default(ACTIVE)

  // Relations
  task        Task        @relation(fields: [taskId], references: [id])
  taskId      String
  employee    User        @relation(fields: [employeeId], references: [id])
  employeeId  String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([employeeId])
  @@index([taskId])
  @@index([date])
  @@index([status])
  @@map("time_records")
}

model Comment {
  id      String @id @default(uuid())
  content String

  // Can be attached to task or project
  task      Task?    @relation(fields: [taskId], references: [id])
  taskId    String?
  project   Project? @relation(fields: [projectId], references: [id])
  projectId String?

  // Relations
  author    User              @relation(fields: [authorId], references: [id])
  authorId  String
  files     FileAttachment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([taskId])
  @@index([projectId])
  @@map("comments")
}

model FileAttachment {
  id           String  @id @default(uuid())
  filename     String
  originalName String
  mimeType     String
  size         Int
  path         String
  version      Int     @default(1)

  // Can be attached to task or comment
  task      Task?    @relation(fields: [taskId], references: [id])
  taskId    String?
  comment   Comment? @relation(fields: [commentId], references: [id])
  commentId String?

  // Relations
  uploadedBy   User   @relation(fields: [uploadedById], references: [id])
  uploadedById String

  createdAt DateTime @default(now())

  @@index([taskId])
  @@index([commentId])
  @@map("file_attachments")
}

model Alert {
  id      String    @id @default(uuid())
  type    AlertType
  title   String
  message String
  isRead  Boolean   @default(false)

  // Relations
  sender     User?   @relation("AlertSender", fields: [senderId], references: [id])
  senderId   String?
  receiver   User    @relation("AlertReceiver", fields: [receiverId], references: [id])
  receiverId String

  // Related entities (optional)
  taskId    String?
  projectId String?

  createdAt DateTime @default(now())

  @@index([receiverId, isRead])
  @@map("alerts")
}

model TaskChangeHistory {
  id        String   @id @default(uuid())
  field     String   // What field was changed
  oldValue  String?  // Previous value
  newValue  String?  // New value
  action    String   // CREATE, UPDATE, DELETE

  // Relations
  task      Task     @relation(fields: [taskId], references: [id])
  taskId    String
  changedBy String   // User ID who made the change

  createdAt DateTime @default(now())

  @@index([taskId])
  @@map("task_change_history")
}

model ProjectAssignment {
  id        String   @id @default(uuid())

  // Relations
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId String

  assignedAt DateTime @default(now())
  assignedBy String   // User ID who made the assignment

  @@unique([userId, projectId])
  @@index([userId])
  @@index([projectId])
  @@map("project_assignments")
}

model ProjectClient {
  id         String   @id @default(uuid())

  project    Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId  String
  client     Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  clientId   String

  isPrimary  Boolean  @default(false)
  assignedAt DateTime @default(now())
  assignedBy String   // User ID who made the assignment

  @@unique([projectId, clientId])
  @@index([projectId])
  @@index([clientId])
  @@map("project_clients")
}

model SystemSettings {
  id    String @id @default(uuid())
  key   String @unique
  value String

  updatedAt DateTime @updatedAt

  @@map("system_settings")
}